# === Supabase (obrigatório) ===
VITE_SUPABASE_URL=https://seu-projeto.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sua-anon-key
VITE_SUPABASE_PROJECT_ID=seu-project-id

# === Secrets do Supabase Edge Functions ===
# Configurar via: supabase secrets set NOME=valor
#
# AI_PROVIDER_URL - URL da API compatível com OpenAI (ex: https://generativelanguage.googleapis.com/v1beta/openai, https://api.openai.com/v1)
# AI_API_KEY - Chave da API do provedor de IA
# AI_MODEL - Modelo a usar (ex: gemini-2.5-flash, gpt-4o)
#
# GMAIL_USER - Email Gmail para envio de emails
# GMAIL_APP_PASSWORD - Senha de app do Gmail
